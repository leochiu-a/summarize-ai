{
  "manifest_version": 3,
  "name": "Summarize AI Buddy",
  "version": "1.0.0",
  "description": "在 kkday.com 網頁右下角召喚 pixel 小夥伴，用 Chrome 內建 AI 幫你摘要頁面內容，語氣任選、全程本機運算不上傳",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://kkday.com/*", "*://*.kkday.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "小夥伴設定"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/sprite.png", "assets/emoji/*.svg", "assets/emoji/*.webp"],
      "matches": ["*://kkday.com/*", "*://*.kkday.com/*"]
    }
  ],
  "icons": {
    "128": "assets/icon128.png"
  }
}
